{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src"],
        "excludes": [
            "Entity",
            "Kernel.php",
            "Controller",
            "Command"
        ]
    },
    "logs": {
        "text": "var/infection/infection.log",
        "html": "var/infection/infection.html",
        "summary": "var/infection/summary.log"
    },
    "tmpDir": "var/infection/tmp",
    "phpUnit": {
        "configDir": ".",
        "customPath": "vendor/bin/phpunit"
    },
    "testFramework": "phpunit",
    "testFrameworkOptions": "--testsuite=unit --path-coverage",
    "initialTestsPhpOptions": "-d memory_limit=512M",
    "mutators": {
        "@default": true,
        "global-ignoreSourceCodeByRegex": [
            "\\?\\? 0"
        ]
    },
    // Path coverage (--path-coverage) is stricter than line coverage.
    // Current: MSI ~80%, Covered MSI ~61%. Target: raise as unit test coverage improves.
    "minMsi": 50,
    "minCoveredMsi": 50
}
