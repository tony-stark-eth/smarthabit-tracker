{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src"],
        "excludes": [
            "Entity",
            "Kernel.php",
            "Controller",
            "Command"
        ]
    },
    "logs": {
        "text": "var/infection/infection.log",
        "summary": "var/infection/summary.log"
    },
    "tmpDir": "var/infection/tmp",
    "phpUnit": {
        "configDir": ".",
        "customPath": "vendor/bin/phpunit"
    },
    "testFramework": "phpunit",
    "testFrameworkOptions": "--testsuite=unit --path-coverage",
    "initialTestsPhpOptions": "-d memory_limit=512M",
    "mutators": {
        "@default": true,
        "global-ignoreSourceCodeByRegex": [
            "\\?\\? 0"
        ],
        "UnwrapRtrim": {
            "ignore": [
                "App\\Notification\\Service\\ApnsJwtGenerator"
            ]
        }
    },
    // Path coverage (--path-coverage) is stricter than line coverage.
    // Current: MSI 92%, Covered MSI 92%. Remaining 35 escaped mutants are mostly harmless.
    "minMsi": 80,
    "minCoveredMsi": 80
}
