{
    "name": "frontend",
    "private": true,
    "type": "module",
    "scripts": {
        "i18n:generate": "bun run scripts/generate-i18n.ts",
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "eslint .",
        "format": "prettier --write .",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "cap:sync": "cap sync",
        "cap:ios": "cap open ios",
        "cap:android": "cap open android",
        "cap:build": "bun run build && cap sync"
    },
    "devDependencies": {
        "@capacitor/cli": "^8.2.0",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.58.2",
        "@sveltejs/adapter-static": "latest",
        "@sveltejs/kit": "^2",
        "@sveltejs/vite-plugin-svelte": "latest",
        "@tailwindcss/vite": "latest",
        "@types/node": "^25.5.0",
        "eslint": "latest",
        "eslint-plugin-svelte": "latest",
        "globals": "^17.4.0",
        "prettier": "latest",
        "prettier-plugin-svelte": "latest",
        "sirv-cli": "^3.0.1",
        "svelte": "^5",
        "svelte-check": "latest",
        "tailwindcss": "^4",
        "typescript": "^6.0",
        "typescript-eslint": "^8.57.1",
        "vite": "^6",
        "yaml": "^2.8.3"
    },
    "dependencies": {
        "@capacitor/app": "^8.0.1",
        "@capacitor/core": "^8.2.0",
        "@capacitor/haptics": "^8.0.1",
        "@capacitor/push-notifications": "^8.0.2",
        "@capacitor/status-bar": "^8.0.1",
        "@openobserve/browser-logs": "^0.3.1",
        "@openobserve/browser-rum": "^0.3.1"
    }
}
