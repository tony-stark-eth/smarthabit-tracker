# Caddyfile — Same-Origin Architecture
# API and frontend served under one domain, no CORS required.
#
# Dev:  Caddy serves only the API. The Vite dev server runs on port 5173
#       and proxies API requests to this Caddy instance.
# Prod: Caddy serves both the API and the SvelteKit static build.

# ─── Global Options ──────────────────────────────────────────────────────────
# Trust Cloudflare proxy IPs so client_ip in logs shows the real visitor,
# not the Cloudflare edge node. Required for fail2ban to ban the right IP.
# Source: https://www.cloudflare.com/ips/
{
	servers {
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
	}
}

# ─── External (HTTPS) ─────────────────────────────────────────────────────────
{$SERVER_NAME:localhost} {
    log {
        output file /var/log/caddy/access.log {
            roll_size 10MiB
            roll_keep 5
        }
    }

    # ── Security Headers ────────────────────────────────────────────────────────
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # API requests → Symfony / FrankenPHP
    handle /api/* {
        root * /app/public
        php_server
    }

    # Mercure Hub — Server-Sent Events for real-time updates
    handle /.well-known/mercure {
        mercure {
            transport bolt {
                path {$MERCURE_DB_PATH:/tmp/mercure.db}
            }
            publisher_jwt {env.MERCURE_JWT_SECRET}
            subscriber_jwt {env.MERCURE_JWT_SECRET}
        }
    }

    handle /ntfy/* {
        uri strip_prefix /ntfy
        reverse_proxy ntfy:80
    }

    # Everything else → SvelteKit static build with SPA fallback
    handle {
        root * /app/frontend/build

        # Service worker must never be cached by CDN/browser — a stale SW
        # serves old assets indefinitely, even after deployment.
        @serviceWorker path /service-worker.js
        header @serviceWorker Cache-Control "no-cache, no-store, must-revalidate"

        # index.html should also be revalidated (SPA entry point)
        @html path /index.html /
        header @html Cache-Control "no-cache"

        try_files {path} /index.html
        file_server
    }
}

# ─── Internal HTTP (no TLS) ────────────────────────────────────────────────────
# Used by Docker service-to-service communication (e.g. Vite proxy inside Docker).
# Not exposed to the internet — only reachable within the Docker network.
:8080 {
    root * /app/public

    handle /api/* {
        php_server
    }
}
