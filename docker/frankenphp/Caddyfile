# Caddyfile — Same-Origin Architecture
# API and frontend served under one domain, no CORS required.
#
# Dev:  Caddy serves only the API. The Vite dev server runs on port 5173
#       and proxies API requests to this Caddy instance.
# Prod: Caddy serves both the API and the SvelteKit static build.

# ─── External (HTTPS) ─────────────────────────────────────────────────────────
{$SERVER_NAME:localhost} {
    log

    # API requests → Symfony / FrankenPHP
    handle /api/* {
        root * /app/public
        php_server
    }

    # Mercure Hub — Server-Sent Events for real-time updates
    handle /.well-known/mercure {
        mercure {
            transport bolt {
                path {$MERCURE_DB_PATH:/tmp/mercure.db}
            }
            publisher_jwt {env.MERCURE_JWT_SECRET}
            subscriber_jwt {env.MERCURE_JWT_SECRET}
        }
    }

    handle /ntfy/* {
        uri strip_prefix /ntfy
        reverse_proxy ntfy:80
    }

    # Everything else → SvelteKit static build with SPA fallback
    handle {
        root * /app/frontend/build
        try_files {path} /index.html
        file_server
    }
}

# ─── Internal HTTP (no TLS) ────────────────────────────────────────────────────
# Used by Docker service-to-service communication (e.g. Vite proxy inside Docker).
# Not exposed to the internet — only reachable within the Docker network.
:8080 {
    root * /app/public

    handle /api/* {
        php_server
    }
}
